# Combined .gitignore templates for OS/editor noise plus per-stack build
# artifacts. Use as-is (git config --global core.excludesfile), or copy just
# the sections you need into a project's .gitignore and delete the rest.

### Windows ###
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

### macOS ###
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

### Linux ###
*~
.directory
.Trash-*
.nfs*

### VS Code ###
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace
.history/

### JetBrains (IntelliJ, Rider, PyCharm, WebStorm, ...) ###
.idea/
*.iml
*.iws

### Sublime Text ###
*.sublime-workspace
*.sublime-project

### Vim ###
*.swp
*.swo

### Build output & env (shared across stacks) ###
bin/
build/
dist/
out/
*.log
.env
.env.local

### Python ###
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments
.venv/
venv/
env/
ENV/

# Testing / coverage
.pytest_cache/
.tox/
.nox/
.coverage
.coverage.*
htmlcov/

# Type checking
.mypy_cache/
.pyright/
.ruff_cache/

# Distribution / packaging
*.egg-info/
.eggs/

# Jupyter
.ipynb_checkpoints/

### JavaScript ###
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

### TypeScript ###
*.tsbuildinfo
*.d.ts.map

### Go ###
*.exe
*.exe~
*.dll
*.dylib
*.test
*.out
vendor/
go.work
go.work.sum

### .NET (C#) ###
obj/
.vs/
*.user
*.suo
*.userosscache
*.sln.docstates
*.sln.iml

# Build results
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/

# Test results
[Tt]est[Rr]esult*/
*.trx
*.coverage
*.coveragexml

# NuGet
*.nupkg
*.snupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/
.nuget/

# ASP.NET
project.lock.json
project.fragment.lock.json
artifacts/

# Env / secrets
appsettings.*.local.json
secrets.json
