{
    // === Theme & Appearance ===
    "workbench.colorTheme": "Dark Modern",
    "workbench.iconTheme": "vscode-icons",
    "workbench.activityBar.location": "top",
    "workbench.layoutControl.enabled": false,
    "workbench.editor.empty.hint": "hidden",
    "workbench.tips.enabled": false,
    "workbench.startupEditor": "none",
    "workbench.statusBar.visible": true,

    // === Editor – Look & Feel ===
    "editor.fontSize": 14,
    "editor.fontWeight": "normal",
    "editor.lineHeight": 1.6,
    "editor.padding.top": 10,
    "editor.minimap.enabled": false,
    "breadcrumbs.enabled": false,
    "editor.cursorBlinking": "solid",
    "editor.cursorSmoothCaretAnimation": "on",
    "editor.smoothScrolling": true,
    "editor.renderLineHighlight": "gutter",
    "editor.occurrencesHighlight": "off",
    "editor.bracketPairColorization.enabled": true,
    "editor.guides.indentation": false,
    "editor.scrollbar.vertical": "auto",
    "editor.renderWhitespace": "all",

    // === Editor – Behavior ===
    "editor.formatOnSave": true,
    "editor.formatOnPaste": true,
    "editor.detectIndentation": false,
    "editor.defaultFormatter": "ms-dotnettools.csharp",
    "editor.inlineSuggest.edits.allowCodeShifting": "never",

    // === Diff Editor ===
    "diffEditor.ignoreTrimWhitespace": false,

    // === Explorer ===
    "outline.showOnExplorerOutline": false,
    "timeline.showUncommitted": false,
    "timeline.showCommitted": false,
    "explorer.compactFolders": true,
    "explorer.confirmDelete": false,
    "explorer.confirmDragAndDrop": false,
    "explorer.fileNesting.patterns": {
        "*.ts": "${capture}.js",
        "*.js": "${capture}.js.map, ${capture}.min.js, ${capture}.d.ts",
        "*.jsx": "${capture}.js",
        "*.tsx": "${capture}.ts",
        "tsconfig.json": "tsconfig.*.json",
        "package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml, bun.lockb, bun.lock",
        "*.cs": "${capture}.designer.cs,${capture}.g.cs,${capture}.generated.cs,${capture}.run.json,${capture}.settings.json,${capture}.settings.*.json",
        "*.csproj": "${capture}.csproj.user",
        "*.json": "${capture}.Development.json",
        "*.cshtml": "${capture}.cshtml.cs,${capture}.cshtml.css",
        "*.razor": "${capture}.razor.cs,${capture}.razor.css",
        "*.resx": "${capture}.Designer.cs",
        "*.xaml": "${capture}.xaml.cs",
        "*.sqlite": "${capture}.${extname}-*",
        "*.db": "${capture}.${extname}-*",
        "*.sqlite3": "${capture}.${extname}-*",
        "*.db3": "${capture}.${extname}-*",
        "*.sdb": "${capture}.${extname}-*",
        "*.s3db": "${capture}.${extname}-*"
    },

    // === Terminal ===
    "terminal.integrated.fontSize": 13,

    // === Git ===
    "git.confirmSync": false,

    // === C# / .NET ===
    "dotnet.defaultSolution": "disable",
    "omnisharp.enableRoslynAnalyzers": true,

    // === TypeScript / JavaScript ===
    "js/ts.suggest.paths": false,

    // === Python ===
    "python.defaultInterpreterPath": "c:\\Python312\\python.exe",

    // === PowerShell ===
    "powershell.promptToUpdatePowerShell": false,

    // === GitHub Copilot ===
    "github.copilot.enable": {
        "*": false
    },
    "github.copilot.nextEditSuggestions.enabled": true,
    "github.copilot.chat.localeOverride": "en",
    "github.copilot.chat.reviewSelection.instructions": [],
    "github.copilot.chat.codesearch.enabled": true,
    "github.copilot.advanced": {
        "authProvider": "github-enterprise"
    },

    // === GitHub Enterprise ===
    "github-enterprise.uri": "https://shs.ghe.com",

    // === Chat ===
    "chat.mcp.gallery.enabled": true,
    "chat.tools.terminal.autoApprove": {
        "type": true,
        "ConvertFrom-Json": true
    },
    "chat.viewSessions.orientation": "stacked",

    // === Extensions ===
    "extensions.autoUpdate": "off",
    "chatCustomizationsEvaluations.waza.command": "c:\\Users\\z0050uzx\\AppData\\Roaming\\Code\\User\\globalStorage\\ms-vscode.vscode-chat-customizations-evaluations\\bin\\waza.exe",
}